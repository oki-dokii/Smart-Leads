# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
MONGODB_URI=mongodb://mongo_user:mongo_pass@mongo:27017/smart-leads?authSource=admin
JWT_SECRET=your_super_secret_jwt_key_here

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:80

# ── MongoDB (Docker) ──────────────────────────────────────────────────────────
MONGO_ROOT_USER=mongo_user
MONGO_ROOT_PASS=mongo_pass
